# Production environment variables (example)
# Copy this to .env.prod (or inject into your container/orchestration) and fill values.

# MongoDB connection string (use credentials + replica set URL in production)
MONGODB_URI=mongodb://username:password@mongo-host:27017/election

# Backend service configuration
PORT=5000
NODE_ENV=production

# Optional secret for signing tokens (not required by the current mock auth implementation)
JWT_SECRET=change-me-to-a-secure-random-string

# API base URL exposed to clients (used by web app when built with VITE_API_URL)
VITE_API_URL=https://api.example.com

# Additional runtime flags
# LOG_LEVEL=info
# SENTRY_DSN=
