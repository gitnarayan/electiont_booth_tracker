# Production multi-stage Dockerfile for web (Vite)
FROM node:18-alpine AS builder
WORKDIR /usr/src/app

# Install dependencies
COPY package*.json ./
RUN npm ci --silent

# Copy source and build
COPY . .
RUN npm run build

# Nginx static server for production
FROM nginx:stable-alpine AS runner
COPY --from=builder /usr/src/app/dist /usr/share/nginx/html

# Remove default nginx config if customizing is needed (keeping default for simplicity)
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
